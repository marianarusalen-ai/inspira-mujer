---
import { SITE, NAV_FOOTER, NAV_LEGAL, SOCIAL, CONTACT } from '@/config';
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import { interpolate } from '@/i18n/utils';

type SocialEntry = { icon: string; label: string; url: string };

const allPlatforms: { icon: string; label: string; url: string | undefined }[] = [
  { icon: 'instagram', label: 'Instagram', url: SOCIAL.instagram },
  { icon: 'youtube',   label: 'YouTube',   url: SOCIAL.youtube   },
  { icon: 'external-link', label: 'Facebook', url: SOCIAL.facebook },
  { icon: 'external-link', label: 'TikTok',   url: SOCIAL.tiktok   },
];

const socialPlatforms: SocialEntry[] = allPlatforms.filter(
  (p): p is SocialEntry => p.url !== undefined
);
---

<footer role="contentinfo" id="site-footer" class="bg-surface-dark text-text-inverse">

  <!-- Main footer grid -->
  <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

    <!-- Col 1: Logo + tagline -->
    <div class="sm:col-span-2 lg:col-span-1">
      <a
        href="/"
        class="font-display font-bold text-xl text-text-inverse hover:text-primary-light transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-light rounded"
        aria-label={`${SITE.name} — Inicio`}
      >
        {SITE.name}
      </a>
      <p class="mt-3 text-sm text-text-inverse/70 leading-relaxed max-w-xs">
        {SITE.tagline}
      </p>
    </div>

    <!-- Col 2: Navegación -->
    <div>
      <h2 class="text-sm font-semibold text-text-inverse uppercase tracking-wider mb-4">
        Navegación
      </h2>
      <nav aria-label="Navegación de pie de página">
        <ul class="flex flex-col gap-2">
          {NAV_FOOTER.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-text-inverse/70 hover:text-text-inverse transition-colors focus-visible:outline-none focus-visible:underline"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Col 3: Redes sociales + Contacto -->
    <div class="flex flex-col gap-6">
      <div>
        <h2 class="text-sm font-semibold text-text-inverse uppercase tracking-wider mb-4">
          Redes sociales
        </h2>
        <nav aria-label="Redes sociales de Inspira Mujer">
          <ul class="flex flex-col gap-2">
            {socialPlatforms.map(({ icon, label, url }) => (
              <li>
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={interpolate('Seguinos en {{platform}}', { platform: label })}
                  class="inline-flex items-center gap-2 text-sm text-text-inverse/70 hover:text-text-inverse transition-colors focus-visible:outline-none focus-visible:underline"
                >
                  <Icon name={icon} size="sm" />
                  <span>{label}</span>
                  <Icon name="external-link" size="xs" class="opacity-50" />
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-text-inverse uppercase tracking-wider mb-3">
          Contacto
        </h2>
        <ul class="flex flex-col gap-2 text-sm text-text-inverse/70">
          <li class="flex items-center gap-2">
            <Icon name="mail" size="sm" class="flex-shrink-0" />
            <a
              href={`mailto:${CONTACT.email}`}
              class="hover:text-text-inverse transition-colors focus-visible:outline-none focus-visible:underline"
            >
              {CONTACT.email}
            </a>
          </li>
          <li class="flex items-start gap-2">
            <Icon name="map-pin" size="sm" class="flex-shrink-0 mt-0.5" />
            <span>{CONTACT.location}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Col 4: Newsletter — envío real pendiente de definir proveedor (n8n, Resend, u otro) -->
    <div>
      <h2 class="text-sm font-semibold text-text-inverse uppercase tracking-wider mb-2">
        Newsletter
      </h2>
      <p class="text-sm text-text-inverse/70 mb-4">
        Muy pronto: novedades, eventos y recursos en tu correo.
      </p>
      <form
        aria-label="Suscripción al newsletter"
        class="flex flex-col gap-2"
        novalidate
      >
        <div class="flex gap-2">
          <label for="footer-newsletter-email" class="sr-only">
            Correo electrónico
          </label>
          <input
            id="footer-newsletter-email"
            name="email"
            type="email"
            placeholder="tu@email.com"
            required
            autocomplete="email"
            aria-required="true"
            disabled
            class="flex-1 min-w-0 rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-sm text-text-inverse placeholder:text-text-inverse/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-light transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          />
          <Button type="submit" variant="primary" size="sm" disabled>
            Muy pronto
          </Button>
        </div>
      </form>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-content mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-text-inverse/50">
      <p>
        &copy; {new Date().getFullYear()} {SITE.name}. Todos los derechos reservados.
      </p>
      <nav aria-label="Navegación legal">
        <ul class="flex flex-wrap gap-4">
          {NAV_LEGAL.map((item) => (
            <li>
              <a
                href={item.href}
                class="hover:text-text-inverse transition-colors focus-visible:outline-none focus-visible:underline"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>

</footer>
