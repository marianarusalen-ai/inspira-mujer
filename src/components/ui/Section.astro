---
import { cn } from '@/lib';

type SectionSpacing = 'none' | 'sm' | 'md' | 'lg' | 'xl';
type SectionWidth = 'content' | 'prose' | 'full';
type SectionBackground = 'default' | 'alt' | 'dark';

interface Props {
  as?: 'section' | 'div' | 'article' | 'aside';
  id?: string;
  labelledBy?: string;
  spacing?: SectionSpacing;
  width?: SectionWidth;
  background?: SectionBackground;
  class?: string;
}

const {
  as: tag = 'section',
  id,
  labelledBy,
  spacing = 'lg',
  width = 'content',
  background = 'default',
  class: className,
} = Astro.props as Props;

const spacingClasses: Record<SectionSpacing, string> = {
  none: '',
  sm: 'py-6 px-4',
  md: 'py-10 px-4',
  lg: 'py-16 px-4',
  xl: 'py-24 px-4',
};

const widthClasses: Record<SectionWidth, string> = {
  content: 'max-w-content mx-auto',
  prose: 'max-w-prose mx-auto',
  full: 'w-full',
};

const backgroundClasses: Record<SectionBackground, string> = {
  default: 'bg-surface',
  alt: 'bg-surface-alt',
  dark: 'bg-surface-dark text-text-inverse',
};

const outerClasses = cn(backgroundClasses[background], className);
const innerClasses = cn(spacingClasses[spacing], widthClasses[width]);
---

{tag === 'section' && (
  <section id={id} aria-labelledby={labelledBy} class={outerClasses}>
    <div class={innerClasses}><slot /></div>
  </section>
)}
{tag === 'article' && (
  <article id={id} aria-labelledby={labelledBy} class={outerClasses}>
    <div class={innerClasses}><slot /></div>
  </article>
)}
{tag === 'aside' && (
  <aside id={id} aria-labelledby={labelledBy} class={outerClasses}>
    <div class={innerClasses}><slot /></div>
  </aside>
)}
{tag === 'div' && (
  <div id={id} aria-labelledby={labelledBy} class={outerClasses}>
    <div class={innerClasses}><slot /></div>
  </div>
)}
