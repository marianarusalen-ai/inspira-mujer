---
import { cn } from '@/lib';

type TagColor = 'default' | 'primary' | 'accent' | 'success' | 'warning';

interface Props {
  href?: string;
  color?: TagColor;
  class?: string;
}

const { href, color = 'default', class: className } = Astro.props;

const base =
  'inline-flex items-center rounded-md px-2 py-1 text-xs font-medium transition-colors';

const colors: Record<TagColor, string> = {
  default: 'bg-surface-alt text-text-muted hover:bg-border',
  primary: 'bg-primary/10 text-primary-dark hover:bg-primary/20',
  accent: 'bg-accent/10 text-accent hover:bg-accent/20',
  success: 'bg-success/10 text-success hover:bg-success/20',
  warning: 'bg-warning/10 text-warning hover:bg-warning/20',
};

const classes = cn(base, colors[color], className);
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <span class={classes}>
      <slot />
    </span>
  )
}
