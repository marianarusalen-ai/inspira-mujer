---
import { cn } from '@/lib';

interface Props {
  id: string;
  label: string;
  name: string;
  value?: string;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  rows?: number;
  error?: string;
  hint?: string;
  class?: string;
}

const {
  id,
  label,
  name,
  value,
  placeholder,
  required = false,
  disabled = false,
  rows = 4,
  error,
  hint,
  class: className,
} = Astro.props;

const hasError = Boolean(error);
const errorId = `${id}-error`;
const hintId = `${id}-hint`;
const describedBy =
  [hasError ? errorId : null, hint ? hintId : null].filter(Boolean).join(' ') || undefined;

const textareaBase =
  'w-full rounded-lg border px-3 py-2 text-sm text-text bg-surface placeholder:text-text-subtle transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-1 disabled:cursor-not-allowed disabled:opacity-50 resize-y min-h-[6rem]';

const textareaVariant = hasError
  ? 'border-error focus-visible:ring-error'
  : 'border-border hover:border-border-strong';

const textareaClasses = cn(textareaBase, textareaVariant, className);
---

<div class="flex flex-col gap-1.5">
  <label for={id} class={cn('text-sm font-medium text-text', disabled && 'opacity-50')}>
    {label}
    {required && <span class="text-error ml-0.5" aria-hidden="true">*</span>}
  </label>

  {hint && (
    <p id={hintId} class="text-xs text-text-subtle">
      {hint}
    </p>
  )}

  <textarea
    id={id}
    name={name}
    rows={rows}
    required={required}
    disabled={disabled}
    placeholder={placeholder}
    aria-required={required ? 'true' : undefined}
    aria-invalid={hasError ? 'true' : undefined}
    aria-describedby={describedBy}
    class={textareaClasses}>{value}</textarea>

  {hasError && error && (
    <p id={errorId} class="text-xs text-error flex items-center gap-1" role="alert">
      <svg
        class="w-3.5 h-3.5 flex-shrink-0"
        aria-hidden="true"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <circle cx="12" cy="12" r="10" />
        <line x1="12" y1="8" x2="12" y2="12" />
        <line x1="12" y1="16" x2="12.01" y2="16" />
      </svg>
      {error}
    </p>
  )}
</div>
