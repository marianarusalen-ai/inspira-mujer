---
import PageLayout from '@/layouts/PageLayout.astro';
import { resolveSeo, buildCanonical } from '@/config';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Card from '@/components/ui/Card.astro';
import Icon from '@/components/ui/Icon.astro';
import Tag from '@/components/ui/Tag.astro';
import Input from '@/components/ui/Input.astro';
import Textarea from '@/components/ui/Textarea.astro';

const seo = resolveSeo({
  title: 'UI Kit — Dev',
  description: 'Página de prueba de componentes. No indexada.',
  canonical: buildCanonical('/dev/ui-kit'),
  noIndex: true,
});

const iconNames = [
  'menu', 'close', 'chevron-down', 'chevron-right', 'chevron-left', 'arrow-right',
  'external-link', 'check', 'alert-circle', 'info', 'instagram', 'youtube',
  'loader', 'mail', 'map-pin', 'calendar',
] as const;

const colorTokens = [
  { name: 'primary', cls: 'bg-primary' },
  { name: 'primary-light', cls: 'bg-primary-light' },
  { name: 'primary-dark', cls: 'bg-primary-dark' },
  { name: 'secondary', cls: 'bg-secondary' },
  { name: 'accent', cls: 'bg-accent' },
  { name: 'surface', cls: 'bg-surface border border-border' },
  { name: 'surface-alt', cls: 'bg-surface-alt' },
  { name: 'surface-dark', cls: 'bg-surface-dark' },
  { name: 'success', cls: 'bg-success' },
  { name: 'warning', cls: 'bg-warning' },
  { name: 'error', cls: 'bg-error' },
  { name: 'info', cls: 'bg-info' },
] as const;
---

<PageLayout seo={seo}>
  <div class="max-w-content mx-auto px-4 py-12 space-y-16">

    <header>
      <h1 class="text-3xl font-display font-bold text-text mb-2">UI Kit — Inspira Mujer</h1>
      <p class="text-text-muted">Página temporal para revisión visual de componentes. Se elimina en Etapa 4.</p>
    </header>

    <!-- BUTTONS -->
    <section aria-labelledby="buttons-heading">
      <h2 id="buttons-heading" class="text-xl font-display font-bold mb-6 pb-2 border-b border-border">
        Button
      </h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-sm font-semibold text-text-muted mb-3 uppercase tracking-wide">Variants</h3>
          <div class="flex flex-wrap gap-3">
            <Button variant="primary">Primary</Button>
            <Button variant="secondary">Secondary</Button>
            <Button variant="outline">Outline</Button>
            <Button variant="ghost">Ghost</Button>
            <Button variant="destructive">Danger</Button>
          </div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-muted mb-3 uppercase tracking-wide">Sizes</h3>
          <div class="flex flex-wrap items-center gap-3">
            <Button size="sm">Small</Button>
            <Button size="md">Medium</Button>
            <Button size="lg">Large</Button>
            <Button size="xl">Extra Large</Button>
          </div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-muted mb-3 uppercase tracking-wide">States</h3>
          <div class="flex flex-wrap gap-3">
            <Button disabled>Disabled</Button>
            <Button loading>Loading</Button>
            <Button variant="outline" disabled>Outline Disabled</Button>
          </div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-muted mb-3 uppercase tracking-wide">As Link</h3>
          <div class="flex flex-wrap gap-3">
            <Button href="/" variant="primary">Link Primary</Button>
            <Button href="https://example.com" target="_blank" variant="outline">Link External</Button>
          </div>
        </div>
      </div>
    </section>

    <!-- BADGES -->
    <section aria-labelledby="badges-heading">
      <h2 id="badges-heading" class="text-xl font-display font-bold mb-6 pb-2 border-b border-border">
        Badge
      </h2>
      <div class="flex flex-wrap gap-3">
        <Badge variant="default">Default</Badge>
        <Badge variant="primary">Primary</Badge>
        <Badge variant="success">Success</Badge>
        <Badge variant="warning">Warning</Badge>
        <Badge variant="error">Error</Badge>
        <Badge variant="info">Info</Badge>
      </div>
    </section>

    <!-- TAGS -->
    <section aria-labelledby="tags-heading">
      <h2 id="tags-heading" class="text-xl font-display font-bold mb-6 pb-2 border-b border-border">
        Tag
      </h2>
      <div class="flex flex-wrap gap-2">
        <Tag>Default</Tag>
        <Tag color="primary">Primary</Tag>
        <Tag color="accent">Accent</Tag>
        <Tag color="success">Success</Tag>
        <Tag color="warning">Warning</Tag>
        <Tag href="/blog/tejido">Link Tag</Tag>
      </div>
    </section>

    <!-- ICONS -->
    <section aria-labelledby="icons-heading">
      <h2 id="icons-heading" class="text-xl font-display font-bold mb-6 pb-2 border-b border-border">
        Icon
      </h2>
      <div class="space-y-4">
        <div>
          <h3 class="text-sm font-semibold text-text-muted mb-3 uppercase tracking-wide">Sizes</h3>
          <div class="flex items-end gap-4 text-primary">
            <Icon name="instagram" size="xs" />
            <Icon name="instagram" size="sm" />
            <Icon name="instagram" size="md" />
            <Icon name="instagram" size="lg" />
            <Icon name="instagram" size="xl" />
          </div>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-text-muted mb-3 uppercase tracking-wide">Catalog</h3>
          <div class="flex flex-wrap gap-4 text-text-muted">
            {iconNames.map((name) => (
              <div class="flex flex-col items-center gap-1">
                <Icon name={name} size="md" />
                <span class="text-xs">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CARDS -->
    <section aria-labelledby="cards-heading">
      <h2 id="cards-heading" class="text-xl font-display font-bold mb-6 pb-2 border-b border-border">
        Card
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <Card>
          <h3 class="font-semibold mb-2">Card básica</h3>
          <p class="text-text-muted text-sm">Contenido de ejemplo para la card básica sin enlace.</p>
        </Card>
        <Card href="/programa">
          <h3 class="font-semibold mb-2">Card clickeable</h3>
          <p class="text-text-muted text-sm">Esta card completa es un enlace. Hover para ver sombra.</p>
        </Card>
        <Card>
          <h3 class="font-semibold mb-2">Card con footer</h3>
          <p class="text-text-muted text-sm">Card con slot de footer separado.</p>
          <div slot="footer" class="flex justify-between items-center">
            <Badge variant="primary">Etiqueta</Badge>
            <Button size="sm" variant="ghost">Ver más</Button>
          </div>
        </Card>
      </div>
    </section>

    <!-- FORMS -->
    <section aria-labelledby="forms-heading">
      <h2 id="forms-heading" class="text-xl font-display font-bold mb-6 pb-2 border-b border-border">
        Formularios
      </h2>
      <form class="max-w-prose space-y-6" novalidate>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <Input id="nombre" label="Nombre" name="nombre" type="text" placeholder="María" required />
          <Input
            id="email"
            label="Correo electrónico"
            name="email"
            type="email"
            placeholder="maria@ejemplo.com"
            required
          />
        </div>
        <Input
          id="email-error"
          label="Email con error"
          name="email-error"
          type="email"
          value="correo-invalido"
          error="El formato del correo electrónico no es válido."
          required
        />
        <Input
          id="email-hint"
          label="Email con hint"
          name="email-hint"
          type="email"
          hint="Te enviaremos la confirmación a este correo."
        />
        <Input
          id="email-disabled"
          label="Campo deshabilitado"
          name="email-disabled"
          type="email"
          value="bloqueado@ejemplo.com"
          disabled
        />
        <Textarea
          id="mensaje"
          label="Mensaje"
          name="mensaje"
          placeholder="Escribí tu consulta aquí..."
          required
          rows={5}
        />
        <Textarea
          id="mensaje-error"
          label="Textarea con error"
          name="mensaje-error"
          error="El mensaje no puede estar vacío."
        />
        <div class="flex gap-3">
          <Button type="submit" variant="primary">Enviar mensaje</Button>
          <Button type="reset" variant="outline">Limpiar</Button>
        </div>
      </form>
    </section>

    <!-- COLORS -->
    <section aria-labelledby="colors-heading">
      <h2 id="colors-heading" class="text-xl font-display font-bold mb-6 pb-2 border-b border-border">
        Design Tokens — Colores
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {colorTokens.map(({ name, cls }) => (
          <div class="flex flex-col gap-1">
            <div class={`h-12 rounded-lg ${cls}`} />
            <span class="text-xs text-text-muted">{name}</span>
          </div>
        ))}
      </div>
    </section>

  </div>
</PageLayout>
