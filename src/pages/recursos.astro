---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Section from '@/components/ui/Section.astro';
import Badge from '@/components/ui/Badge.astro';
import Card from '@/components/ui/Card.astro';
import { SITE, resolveSeo, buildCanonical } from '@/config';
import { formatDate } from '@/lib';

const seo = resolveSeo({
  title: 'Recursos',
  description:
    'Tutoriales, guías y herramientas para mujeres que crean. Tejido, macramé, crochet y crecimiento personal.',
  canonical: buildCanonical('/recursos'),
});

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<PageLayout seo={seo}>

  <!-- INTRO -->
  <Section id="recursos-intro" spacing="xl" labelledBy="recursos-heading">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-widest text-link mb-4">
        {SITE.name}
      </p>
      <h1
        id="recursos-heading"
        class="font-display text-4xl sm:text-5xl text-text leading-tight mb-6"
      >
        Recursos
      </h1>
      <p class="text-lg text-text-muted leading-relaxed">
        Tutoriales, guías y materiales para mujeres que crean. Tejido, macramé,
        crochet y todo lo que necesitás para seguir creciendo a tu ritmo.
      </p>
    </div>
  </Section>

  <!-- ARTÍCULOS -->
  <Section id="recursos-articulos" spacing="xl" background="alt" labelledBy="recursos-articulos-heading">
    <h2 id="recursos-articulos-heading" class="font-display text-3xl sm:text-4xl text-text mb-8">
      Artículos
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <Card href={`/recursos/${post.slug}`}>
          <div class="flex flex-col gap-3 h-full">
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => <Badge variant="default">{tag}</Badge>)}
            </div>
            <h3 class="font-display font-bold text-lg text-text leading-snug">
              {post.data.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed flex-1">
              {post.data.description}
            </p>
            <p class="text-text-subtle text-xs mt-2">{formatDate(post.data.publishedAt)}</p>
          </div>
        </Card>
      ))}
    </div>
  </Section>

</PageLayout>
